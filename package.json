{
  "name": "grozo",
  "version": "1.0.0",
  "description": "Grozo - Smart Grocery Ordering & Management System",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "nodemon server/server.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node server/seeds/seed.js",
    "seed:more": "node server/seeds/seedMore.js",
    "build": "cd client && npm install --include=dev && npm run build"
  },
  "keywords": [
    "grocery",
    "mern",
    "ecommerce"
  ],
  "author": "Ashwajeet Singh",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
